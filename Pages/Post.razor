@page "/post/{slug}"

@if (post is null)
{
	return;
}

<div class="Post">
	<div class="Header">
		<h1 style="margin: 15px;">@post.Title</h1>
		<p style="margin-left: 15px">@post.Time.ToString("yyyy-MM-dd HH:mm:ss")</p>
	</div>

	<div class="Content">
		@((MarkupString)post.HTMLContent)
	</div>
</div>

@code
{
	[Parameter]
	public string Slug { get; set; } = string.Empty;

	private PostInfo? post;

	protected override void OnParametersSet()
	{
		post = repo.GetPost(Slug);
		base.OnParametersSet();
	}
}